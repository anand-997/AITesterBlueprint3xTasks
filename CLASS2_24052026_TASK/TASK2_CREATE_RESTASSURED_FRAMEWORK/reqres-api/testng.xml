<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="ReqRes API Suite" parallel="methods" thread-count="5" verbose="1">
    <listeners>
        <listener class-name="com.reqres.api.automation.core.listeners.TestListener"/>
        <listener class-name="com.reqres.api.automation.core.listeners.RetryTransformer"/>
    </listeners>
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.reqres.api.automation.tests.smoke.SmokeTest"/>
        </classes>
    </test>
</suite>
