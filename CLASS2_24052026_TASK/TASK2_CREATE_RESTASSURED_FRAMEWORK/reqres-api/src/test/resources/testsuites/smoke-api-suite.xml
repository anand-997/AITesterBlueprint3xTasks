<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke API Suite" parallel="methods" thread-count="5" verbose="1">
    <listeners>
        <listener class-name="com.reqres.api.automation.core.listeners.TestListener"/>
        <listener class-name="com.reqres.api.automation.core.listeners.RetryTransformer"/>
    </listeners>
    <test name="Smoke Tests">
        <groups><run><include name="smoke"/></run></groups>
        <packages><package name="com.reqres.api.automation.tests"/></packages>
    </test>
</suite>
